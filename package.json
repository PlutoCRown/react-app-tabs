{
  "name": "react-app-tabs",
  "version": "0.1.0",
  "description": "Zero-style nested tabs component for React",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "example": "bun --cwd example run dev",
    "prepublishOnly": "npm run check && npm run build",
    "pack:dry": "npm_config_cache=/tmp/.npm-cache npm pack --dry-run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.8.2"
  }
}
